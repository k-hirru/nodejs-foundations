{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "checkJs": true,
    "maxNodeModuleJsDepth": 1
  },
  "include": [
    "**/*.js"
  ],
  "exclude": [
    "node_modules",
    "module-1",
    "module-2",
    "module-3",
    "module-4",
    "module-5",
    "module-6",
    "module-7",
    "module-8",
    "module-9",
    "module-10-capstone",
    "module-11",
    "module-12",
    "module-13",
  ]
}
